# Orkestra daemon (orkd) — production image for Coolify/Docker deployment.
#
# Build stages:
#   1. planner  — cargo-chef prepares a dependency recipe
#   2. builder  — compiles dependencies (cached), then orkd
#   3. runtime  — minimal image with orkd + claude CLI

# ============================================================================
# Stage 1: Dependency planner (cargo-chef)
# ============================================================================

FROM rust:1.83-slim AS planner

RUN cargo install cargo-chef --locked
WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY daemon/Cargo.toml daemon/
COPY cli/Cargo.toml cli/
COPY relay/Cargo.toml relay/
COPY crates/orkestra-agent/Cargo.toml crates/orkestra-agent/
COPY crates/orkestra-core/Cargo.toml crates/orkestra-core/
COPY crates/orkestra-debug/Cargo.toml crates/orkestra-debug/
COPY crates/orkestra-git/Cargo.toml crates/orkestra-git/
COPY crates/orkestra-networking/Cargo.toml crates/orkestra-networking/
COPY crates/orkestra-parser/Cargo.toml crates/orkestra-parser/
COPY crates/orkestra-process/Cargo.toml crates/orkestra-process/
COPY crates/orkestra-prompt/Cargo.toml crates/orkestra-prompt/
COPY crates/orkestra-relay-protocol/Cargo.toml crates/orkestra-relay-protocol/
COPY crates/orkestra-schema/Cargo.toml crates/orkestra-schema/
COPY crates/orkestra-store/Cargo.toml crates/orkestra-store/
COPY crates/orkestra-types/Cargo.toml crates/orkestra-types/
COPY crates/orkestra-utility/Cargo.toml crates/orkestra-utility/
# src-tauri is in the workspace but we don't build it — include its Cargo.toml
# so cargo-chef can resolve the full workspace, but don't copy its source.
COPY src-tauri/Cargo.toml src-tauri/

RUN cargo chef prepare --recipe-path recipe.json

# ============================================================================
# Stage 2: Builder
# ============================================================================

FROM rust:1.83-slim AS builder

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    git \
    && rm -rf /var/lib/apt/lists/*

RUN cargo install cargo-chef --locked
WORKDIR /app

# Override sccache wrapper from .cargo/config.toml — not available in Docker.
ENV RUSTC_WRAPPER=""

# -- Cook dependencies (cached layer) --
COPY --from=planner /app/recipe.json recipe.json
RUN cargo chef cook --release -p orkd --recipe-path recipe.json

# -- Build orkd --
COPY . .
RUN cargo build --release -p orkd

# ============================================================================
# Stage 3: Runtime
# ============================================================================

FROM debian:bookworm-slim AS runtime

RUN apt-get update && apt-get install -y \
    ca-certificates \
    git \
    curl \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js (for claude CLI)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install claude CLI
RUN npm install -g @anthropic-ai/claude-code

# Install gh CLI (for PR operations)
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/orkd /usr/local/bin/orkd

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 3847

ENTRYPOINT ["/entrypoint.sh"]
