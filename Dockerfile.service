# Orkestra service (ork-service) — production image for Dokploy/Docker deployment.
#
# Builds ork-service and orkd, then packages them with the full agent runtime
# (claude CLI, gh CLI, git).
#
# Build stages:
#   1. planner  — cargo-chef prepares a dependency recipe
#   2. builder  — compiles dependencies (cached), then ork-service + orkd
#   3. runtime  — minimal image with both binaries + agent tooling

# ============================================================================
# Stage 1: Dependency planner (cargo-chef)
# ============================================================================

FROM rust:1.88-slim AS planner

RUN cargo install cargo-chef --locked
WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY cli/Cargo.toml cli/
COPY daemon/Cargo.toml daemon/
COPY relay/Cargo.toml relay/
COPY service/Cargo.toml service/
COPY src-tauri/Cargo.toml src-tauri/
COPY crates/orkestra-agent/Cargo.toml crates/orkestra-agent/
COPY crates/orkestra-core/Cargo.toml crates/orkestra-core/
COPY crates/orkestra-debug/Cargo.toml crates/orkestra-debug/
COPY crates/orkestra-git/Cargo.toml crates/orkestra-git/
COPY crates/orkestra-networking/Cargo.toml crates/orkestra-networking/
COPY crates/orkestra-parser/Cargo.toml crates/orkestra-parser/
COPY crates/orkestra-process/Cargo.toml crates/orkestra-process/
COPY crates/orkestra-prompt/Cargo.toml crates/orkestra-prompt/
COPY crates/orkestra-relay-protocol/Cargo.toml crates/orkestra-relay-protocol/
COPY crates/orkestra-schema/Cargo.toml crates/orkestra-schema/
COPY crates/orkestra-service/Cargo.toml crates/orkestra-service/
COPY crates/orkestra-store/Cargo.toml crates/orkestra-store/
COPY crates/orkestra-types/Cargo.toml crates/orkestra-types/
COPY crates/orkestra-utility/Cargo.toml crates/orkestra-utility/
# Stub source files for all workspace members — cargo metadata requires targets to exist
# even for crates we don't build. Library crates auto-detect src/lib.rs; binary crates
# declare explicit paths to src/main.rs.
RUN for crate in \
        crates/orkestra-agent crates/orkestra-core crates/orkestra-debug \
        crates/orkestra-git crates/orkestra-networking crates/orkestra-parser \
        crates/orkestra-process crates/orkestra-prompt crates/orkestra-relay-protocol \
        crates/orkestra-schema crates/orkestra-service crates/orkestra-store \
        crates/orkestra-types crates/orkestra-utility src-tauri; do \
    mkdir -p "$crate/src" && touch "$crate/src/lib.rs"; \
done && \
for bin in cli daemon relay service; do \
    mkdir -p "$bin/src" && touch "$bin/src/main.rs"; \
done

RUN cargo chef prepare --recipe-path recipe.json

# ============================================================================
# Stage 2: Builder
# ============================================================================

FROM rust:1.88-slim AS builder

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    make \
    perl \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22 LTS + pnpm (needed by service/build.rs to compile the service UI).
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*
RUN npm install -g pnpm

RUN cargo install cargo-chef --locked
WORKDIR /app

# Disable sccache wrapper (not available in Docker).
ENV RUSTC_WRAPPER=""

# -- Cook dependencies (cached layer) --
COPY --from=planner /app/recipe.json recipe.json
RUN cargo chef cook --release -p ork-service -p orkd -p orkestra-cli --recipe-path recipe.json

# -- Install frontend dependencies --
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile

# Accept commit hash at build time so the frontend can embed it.
# Optional for git-connected deployments (Dokploy, etc.) — vite.config.ts reads .git/HEAD directly as fallback.
# For builds without a .git directory: docker build --build-arg COMMIT_HASH=$(git rev-parse --short HEAD)
# Placed after dependency layers so changing the hash doesn't bust the cargo/pnpm caches.
ARG COMMIT_HASH=dev
ENV VITE_COMMIT_HASH=${COMMIT_HASH}
ARG RELEASE_VERSION=
ENV VITE_RELEASE_VERSION=${RELEASE_VERSION}

# -- Build ork-service + orkd --
COPY . .
RUN cargo build --release -p ork-service
RUN cargo build --release -p orkd
RUN cargo build --release -p orkestra-cli

# ============================================================================
# Stage 3: Runtime
# ============================================================================

FROM debian:bookworm-slim AS runtime

RUN apt-get update && apt-get install -y \
    ca-certificates \
    git \
    curl \
    openssh-client \
    gnupg \
    lsb-release \
    && rm -rf /var/lib/apt/lists/*

# Docker CLI (client only — daemon runs on the host via mounted socket).
RUN curl -fsSL https://download.docker.com/linux/debian/gpg \
    | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] \
       https://download.docker.com/linux/debian $(lsb_release -cs) stable" \
    | tee /etc/apt/sources.list.d/docker.list > /dev/null \
    && apt-get update && apt-get install -y docker-ce-cli \
    && rm -rf /var/lib/apt/lists/*

# Node.js (required by claude CLI).
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Claude CLI.
RUN npm install -g @anthropic-ai/claude-code

# GitHub CLI.
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# ork-service and orkd must be in the same directory so the supervisor finds orkd.
COPY --from=builder /app/target/release/ork-service /usr/local/bin/ork-service
COPY --from=builder /app/target/release/orkd /usr/local/bin/orkd
COPY --from=builder /app/target/release/ork /usr/local/bin/ork

# Base Dockerfile — used to build the default dev container image on the host
# when a project has no .devcontainer config.
RUN mkdir -p /etc/orkestra
COPY crates/orkestra-service/Dockerfile.base /etc/orkestra/Dockerfile.base
COPY crates/orkestra-service/Dockerfile.toolbox /etc/orkestra/Dockerfile.toolbox

COPY docker/entrypoint-service.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

HEALTHCHECK --interval=10s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -sf "http://localhost:${SERVICE_PORT:-3847}/health" || exit 1

EXPOSE 3847

ENTRYPOINT ["/entrypoint.sh"]
