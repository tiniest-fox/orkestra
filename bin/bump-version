#!/usr/bin/env bash
# Usage: bin/bump-version <version>
# Updates the version in all canonical locations across the workspace.
set -euo pipefail

VERSION=${1:?Usage: bin/bump-version <version>  (e.g. 0.2.0)}

# Strip leading 'v' if provided
VERSION="${VERSION#v}"

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

echo "Bumping version to $VERSION..."

# package.json
node -e "
  const fs = require('fs');
  const p = JSON.parse(fs.readFileSync('package.json', 'utf8'));
  p.version = '$VERSION';
  fs.writeFileSync('package.json', JSON.stringify(p, null, 2) + '\n');
"
echo "  ✓ package.json"

# src-tauri/tauri.conf.json
node -e "
  const fs = require('fs');
  const p = JSON.parse(fs.readFileSync('src-tauri/tauri.conf.json', 'utf8'));
  p.version = '$VERSION';
  fs.writeFileSync('src-tauri/tauri.conf.json', JSON.stringify(p, null, 2) + '\n');
"
echo "  ✓ src-tauri/tauri.conf.json"

# All Cargo.toml files — replace version only within the [package] section
CARGO_TOML_FILES=(
  src-tauri/Cargo.toml
  cli/Cargo.toml
  daemon/Cargo.toml
  relay/Cargo.toml
  service/Cargo.toml
  crates/orkestra-agent/Cargo.toml
  crates/orkestra-core/Cargo.toml
  crates/orkestra-debug/Cargo.toml
  crates/orkestra-git/Cargo.toml
  crates/orkestra-networking/Cargo.toml
  crates/orkestra-parser/Cargo.toml
  crates/orkestra-process/Cargo.toml
  crates/orkestra-prompt/Cargo.toml
  crates/orkestra-relay-protocol/Cargo.toml
  crates/orkestra-schema/Cargo.toml
  crates/orkestra-service/Cargo.toml
  crates/orkestra-store/Cargo.toml
  crates/orkestra-types/Cargo.toml
  crates/orkestra-utility/Cargo.toml
)

for TOML in "${CARGO_TOML_FILES[@]}"; do
  node -e "
    const fs = require('fs');
    const content = fs.readFileSync('$TOML', 'utf8');
    const updated = content.replace(
      /^(\[package\][^\[]*\nversion\s*=\s*)\"[^\"]*\"/ms,
      '\$1\"$VERSION\"'
    );
    if (updated === content) { console.error('$TOML: version line not found'); process.exit(1); }
    fs.writeFileSync('$TOML', updated);
  "
  echo "  ✓ $TOML"
done

# Regenerate Cargo.lock to reflect the version changes
cargo generate-lockfile --quiet 2>/dev/null || true
echo "  ✓ Cargo.lock"

echo "Done. Version is now $VERSION."
