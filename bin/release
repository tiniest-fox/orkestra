#!/usr/bin/env bash
# Usage: bin/release <version>
# Bumps version in all manifests, verifies the build, commits, tags, and pushes.
set -euo pipefail

VERSION=${1:?Usage: bin/release <version>  (e.g. 0.2.0 or v0.2.0)}

# Strip leading 'v' for the bump script; keep it for the tag
BARE_VERSION="${VERSION#v}"
TAG="v${BARE_VERSION}"

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

# Ensure working tree is clean before we start
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "Error: working tree has uncommitted changes. Commit or stash them first." >&2
  exit 1
fi

# Ensure we're on main
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$CURRENT_BRANCH" != "main" ]; then
  echo "Error: must be on main branch (currently on '$CURRENT_BRANCH')." >&2
  exit 1
fi

# Guard against re-running with an already-existing tag
if git tag -l "$TAG" | grep -q "$TAG"; then
  echo "Error: tag $TAG already exists. Delete it first: git tag -d $TAG" >&2
  exit 1
fi

# Bump versions in all manifests
bin/bump-version "$BARE_VERSION"

echo ""
echo "Running verification suite..."
cargo fmt --all -- --check
echo "  ✓ cargo fmt"
cargo clippy --workspace
echo "  ✓ cargo clippy"
cargo test --workspace
echo "  ✓ cargo test"

# Stage all modified manifests and Cargo.lock
git add \
  package.json \
  src-tauri/tauri.conf.json \
  src-tauri/Cargo.toml \
  cli/Cargo.toml \
  daemon/Cargo.toml \
  relay/Cargo.toml \
  service/Cargo.toml \
  crates/orkestra-agent/Cargo.toml \
  crates/orkestra-core/Cargo.toml \
  crates/orkestra-debug/Cargo.toml \
  crates/orkestra-git/Cargo.toml \
  crates/orkestra-networking/Cargo.toml \
  crates/orkestra-parser/Cargo.toml \
  crates/orkestra-process/Cargo.toml \
  crates/orkestra-prompt/Cargo.toml \
  crates/orkestra-relay-protocol/Cargo.toml \
  crates/orkestra-schema/Cargo.toml \
  crates/orkestra-service/Cargo.toml \
  crates/orkestra-store/Cargo.toml \
  crates/orkestra-types/Cargo.toml \
  crates/orkestra-utility/Cargo.toml \
  Cargo.lock

git commit -m "chore: release $TAG"
git tag "$TAG"

echo ""
echo "Created commit and tag $TAG."
echo "Push to trigger the release build:"
echo ""
echo "  git push origin main $TAG"
echo ""
read -r -p "Push now? [y/N] " CONFIRM
if [[ "$CONFIRM" =~ ^[Yy]$ ]]; then
  git push origin main "$TAG"
  echo ""
  echo "Pushed. GitHub Actions will build the release at:"
  echo "  https://github.com/$(git remote get-url origin | sed 's/.*github.com[:/]//' | sed 's/\.git$//')/actions"
fi
