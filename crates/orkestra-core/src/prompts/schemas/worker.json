{
  "type": "object",
  "description": "Worker output - produces a summary artifact or terminal state",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["summary", "failed", "blocked"],
      "description": "Output type: 'summary' for the work artifact, or terminal states"
    },
    "content": {
      "type": "string",
      "description": "The artifact content (for summary type)"
    },
    "error": {
      "type": "string",
      "description": "Description of what went wrong (for failed type)"
    },
    "reason": {
      "type": "string",
      "description": "Why the task is blocked (for blocked type)"
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata about the work performed",
      "properties": {
        "files_modified": {
          "type": "array",
          "items": { "type": "string" }
        },
        "files_created": {
          "type": "array",
          "items": { "type": "string" }
        },
        "files_deleted": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tests_run": { "type": "boolean" },
        "tests_passed": { "type": "boolean" },
        "build_checked": { "type": "boolean" },
        "build_passed": { "type": "boolean" }
      }
    }
  },
  "required": ["type"]
}
