{
  "description": "Clarifying questions before proceeding",
  "properties": {
    "questions": {
      "type": "array",
      "description": "Questions that need answers",
      "items": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "description": "The question text"
          },
          "context": {
            "type": "string",
            "description": "Why this question matters"
          },
          "options": {
            "type": "array",
            "minItems": 1,
            "description": "Available answer options (required - at least one option)",
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string",
                  "description": "Short display label"
                },
                "description": {
                  "type": "string",
                  "description": "Explanation of this choice"
                }
              },
              "required": ["label"]
            }
          }
        },
        "required": ["question", "options"]
      },
      "minItems": 1
    }
  },
  "required": ["questions"]
}
