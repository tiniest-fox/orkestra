FROM ubuntu:24.04
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git build-essential ca-certificates unzip gnupg && \
    rm -rf /var/lib/apt/lists/*
# Install GitHub CLI so agents can create PRs and interact with GitHub.
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && apt-get install -y --no-install-recommends gh && \
    rm -rf /var/lib/apt/lists/*
# Pin mise to a specific version; download directly from GitHub releases rather
# than piping an unversioned install script. Update MISE_VERSION when upgrading.
ARG MISE_VERSION=2024.12.20
RUN ARCH=$(uname -m | sed 's/x86_64/x64/;s/aarch64/arm64/') && \
    curl -fsSL "https://github.com/jdx/mise/releases/download/v${MISE_VERSION}/mise-v${MISE_VERSION}-linux-${ARCH}" \
    -o /usr/local/bin/mise && chmod +x /usr/local/bin/mise
ENV PATH="/root/.local/bin:/root/.mise/shims:$PATH"
RUN mise settings set experimental true
# Create non-root user for running agents.
# claude CLI refuses --dangerously-skip-permissions when running as root.
# Ubuntu 24.04 ships a built-in "ubuntu" user at uid 1000; rename it to "orkestra"
# rather than creating a new user (which would conflict on the same uid).
# chmod 755 /root so the agent user can access /root/.claude (the bind-mounted auth dir).
RUN usermod -l orkestra -d /home/orkestra -m ubuntu && \
    groupmod -n orkestra ubuntu && \
    chmod 755 /root
# Git credential helper: reads GH_TOKEN from the environment and returns it
# as HTTPS credentials for github.com. Allows non-interactive git push without
# prompting for a username/password. GH_TOKEN is forwarded from the service
# container at `docker run` time.
RUN echo '#!/bin/sh' > /usr/local/bin/git-credential-gh-token && \
    echo '[ "$1" = "get" ] && [ -n "$GH_TOKEN" ] && printf "username=x-access-token\npassword=%s\n" "$GH_TOKEN"' >> /usr/local/bin/git-credential-gh-token && \
    chmod +x /usr/local/bin/git-credential-gh-token
# Set git identity for the orkestra user so commits don't fail with "Author identity unknown".
# Also register the GH_TOKEN credential helper.
USER orkestra
RUN git config --global user.email "agent@orkestra.local" && \
    git config --global user.name "Orkestra Agent" && \
    git config --global credential.helper gh-token
USER root
# Install Node.js 22 LTS via NodeSource (binary ends up at /usr/local/bin)
# then install the Claude Code CLI globally so `claude` is on PATH.
ARG NODE_MAJOR=22
RUN curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
        | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" \
        > /etc/apt/sources.list.d/nodesource.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends nodejs && \
    npm install -g @anthropic-ai/claude-code pnpm && \
    rm -rf /var/lib/apt/lists/*
WORKDIR /workspace
CMD ["sleep", "infinity"]
