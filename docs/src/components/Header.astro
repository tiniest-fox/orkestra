---
import GitHub from "./icons/GitHub.astro";
import Orkestra from "./icons/Orkestra.astro";

interface Props {
  activePage: "docs" | "releases";
}

const { activePage } = Astro.props;
---

<header class="h-14 border-b border-border bg-surface flex items-center px-6 gap-4 sticky top-0 z-10">
  <a href="/" class="flex items-center gap-2.5 shrink-0 group">
    <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-accent to-violet flex items-center justify-center">
      <Orkestra size={14} />
    </div>
    <span class="text-sm font-semibold tracking-wide text-text-primary group-hover:text-accent transition-colors">
      Orkestra
    </span>
  </a>
  <div class="w-px h-5 bg-border"></div>
  <nav class="flex items-center gap-1">
    <a
      href="/docs/getting-started"
      class={`px-2.5 py-1 rounded text-xs font-medium transition-colors ${activePage === "docs" ? "text-accent bg-accent/8" : "text-text-tertiary hover:text-text-secondary"}`}
    >Docs</a>
    <a
      href="/releases"
      class={`px-2.5 py-1 rounded text-xs font-medium transition-colors ${activePage === "releases" ? "text-accent bg-accent/8" : "text-text-tertiary hover:text-text-secondary"}`}
    >Releases</a>
  </nav>
  <div class="flex-1"></div>
  <a
    href="https://github.com/tiniest-fox/orkestra"
    class="flex items-center gap-1.5 text-xs text-text-tertiary hover:text-text-secondary transition-colors"
    target="_blank"
    rel="noopener noreferrer"
  >
    <GitHub size={15} />
    GitHub
  </a>
</header>
