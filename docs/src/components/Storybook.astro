---
interface Props {
  story: string;
  height?: number;
}

const BASE = "https://storybook.orkestra.codes";

const { story, height = 700 } = Astro.props;
const src = `${BASE}/iframe.html?id=${story}&viewMode=story`;
---

<div class="rounded-panel border border-border shadow-panel overflow-hidden">
  <div class="flex items-center gap-2 px-4 py-3 bg-surface border-b border-border">
    <div class="flex gap-1.5">
      <span class="w-3 h-3 rounded-full bg-border"></span>
      <span class="w-3 h-3 rounded-full bg-border"></span>
      <span class="w-3 h-3 rounded-full bg-border"></span>
    </div>
    <span class="text-xs text-text-tertiary font-mono ml-2">storybook.orkestra.codes</span>
  </div>
  <iframe
    src={src}
    class="w-full border-0"
    style={`height: ${height}px;`}
    title="Orkestra — interactive demo"
    loading="lazy"
    allow="clipboard-write"
  ></iframe>
</div>
