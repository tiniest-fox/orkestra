---
// Wraps an ordered list with accent-colored number circles.
// Each step should have a bold title paragraph followed by a body paragraph:
//
//   <Steps>
//   1. **Title**
//
//      Body text here.
//
//   2. **Next step**
//
//      More detail.
//   </Steps>
---

<div class="steps not-prose my-6">
  <slot />
</div>

<style>
  .steps :global(ol) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    counter-reset: steps;
  }

  /* Circle is absolutely positioned so li content always flows as a normal block. */
  .steps :global(ol > li) {
    counter-increment: steps;
    position: relative;
    padding-left: 2.75rem; /* 1.75rem circle + 1rem gap */
    margin: 0;
  }

  .steps :global(ol > li::before) {
    content: counter(steps);
    position: absolute;
    left: 0;
    top: 0.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 9999px;
    background-color: var(--forge-accent);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
  }

  /* Title — first paragraph inside the step */
  .steps :global(ol > li p:first-child) {
    font-weight: 600;
    color: var(--forge-text-primary);
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0 0 0.25rem;
  }

  /* Body — subsequent paragraphs */
  .steps :global(ol > li p:not(:first-child)) {
    color: var(--forge-text-secondary);
    font-size: 0.875rem;
    line-height: 1.625;
    margin: 0;
  }

  .steps :global(ol > li strong) {
    color: var(--forge-text-primary);
    font-weight: 600;
  }

  .steps :global(ol > li code) {
    font-family: var(--font-mono);
    background-color: var(--forge-surface-2);
    color: var(--forge-text-primary);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.8125rem;
    border: 1px solid var(--forge-border);
  }

  .steps :global(ol > li a) {
    color: var(--forge-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .steps :global(ol > li pre) {
    margin-top: 0.5rem;
    background-color: var(--forge-surface-2);
    border: 1px solid var(--forge-border);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    overflow-x: auto;
  }

  .steps :global(ol > li pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.8125rem;
  }
</style>
