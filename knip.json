{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["src/service/main.tsx", "src/docs-api.ts", "src/stories/**/*.stories.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "ignore": ["src/**/*.test.{ts,tsx}", "src/test/**", "docs/**"],
  "ignoreDependencies": ["vite-plugin-pwa", "@testing-library/*", "http-server"],
  "ignoreExportsUsedInFile": true,
  "vitest": false
}
