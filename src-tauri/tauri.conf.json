{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orkestra",
  "version": "0.1.2",
  "identifier": "com.orkestra",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cargo build --release --bin ork && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "resources": {
      "../target/release/ork": "ork"
    }
  }
}
